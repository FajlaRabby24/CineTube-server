model Media {
  id               String    @id @default(cuid())
  title            String
  slug             String    @unique
  synopsis         String
  type             MediaType
  releaseYear      Int
  ageRating        AgeRating @default(PG) // ✅ NEW
  duration         Int? // minutes — movies only
  totalSeasons     Int? // series only
  totalEpisodes    Int? // series only
  posterUrl        String?
  backdropUrl      String?
  trailerUrl       String?
  youtubeStreamUrl String? // YouTube embed URL for streaming
  imdbId           String? // optional IMDB reference
  language         String    @default("English")
  country          String?

  // Pricing & visibility
  pricingType PricingType   @default(FREE)
  status      ContentStatus @default(DRAFT)

  // Aggregated stats — denormalized for performance
  averageRating Float @default(0)
  totalReviews  Int   @default(0)
  totalViews    Int   @default(0)

  // Admin curated flags
  isFeatured    Boolean @default(false)
  isEditorsPick Boolean @default(false)
  isTrending    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  genres           MediaGenre[]
  platforms        MediaPlatform[]
  castMembers      MediaCast[]
  directors        MediaDirector[]
  reviews          Review[]
  watchlistEntries Watchlist[]
  tags             MediaTag[]

  @@index([type])
  @@index([releaseYear])
  @@index([pricingType])
  @@index([averageRating])
  @@index([status])
  @@index([isFeatured])
  @@index([isTrending])
  @@map("media")
}

model MediaGenre {
  id      String @id @default(cuid())
  mediaId String
  genre   Genre

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, genre])
  @@map("media_genre")
}

model MediaPlatform {
  id        String            @id @default(cuid())
  mediaId   String
  platform  StreamingPlatform
  streamUrl String?

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, platform])
  @@map("media_platform")
}

model MediaCast {
  id         String  @id @default(cuid())
  mediaId    String
  actorName  String
  character  String?
  profileUrl String?
  orderIndex Int     @default(0)

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([mediaId])
  @@map("media_cast")
}

model MediaDirector {
  id           String  @id @default(cuid())
  mediaId      String
  directorName String
  profileUrl   String?

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([mediaId])
  @@map("media_director")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique // "classic", "underrated", "family-friendly"
  slug      String   @unique
  createdAt DateTime @default(now())

  mediaTags  MediaTag[]
  reviewTags ReviewTag[]

  @@map("tag")
}

model MediaTag {
  id      String @id @default(cuid())
  mediaId String
  tagId   String

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([mediaId, tagId])
  @@map("media_tag")
}
