model Media {
  id               String    @id @default(cuid())
  title            String
  slug             String    @unique
  synopsis         String
  type             MediaType
  releaseYear      Int
  ageRating        AgeRating @default(PG)
  duration         Int? // minutes
  youtubeStreamUrl String?
  language         String    @default("English")
  country          String?

  // Pricing & visibility
  pricingType PricingType   @default(FREE)
  status      ContentStatus @default(DRAFT)

  // Aggregated stats
  averageRating Float @default(0)
  totalReviews  Int   @default(0)
  totalViews    Int   @default(0)
  totalLikes    Int   @default(0)
  totalDislikes Int   @default(0)

  // Admin curated flags
  isFeatured    Boolean @default(false)
  isEditorsPick Boolean @default(false)
  isTrending    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  genres           MediaGenre[]
  reviews          Review[]
  watchlistEntries Watchlist[]
  tags             MediaTag[]
  votes            MediaVote[]

  @@index([type])
  @@index([releaseYear])
  @@index([pricingType])
  @@index([averageRating])
  @@index([status])
  @@index([isFeatured])
  @@index([isTrending])
  @@map("media")
}

model MediaGenre {
  id      String @id @default(cuid())
  mediaId String
  genre   Genre

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, genre])
  @@map("media_genre")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  mediaTags  MediaTag[]
  reviewTags ReviewTag[]

  @@map("tag")
}

model MediaTag {
  id      String @id @default(cuid())
  mediaId String
  tagId   String

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([mediaId, tagId])
  @@map("media_tag")
}

model MediaVote {
  id        String   @id @default(cuid())
  mediaId   String
  userId    String
  type      VoteType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mediaId, userId])
  @@map("media_vote")
}
