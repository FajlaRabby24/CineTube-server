<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <style>
        body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; background-color: #000; color: #ffffff; margin: 0; padding: 0; }
        .container { max-width: 600px; margin: 0 auto; padding: 40px; background-color: #0a0a0a; border-radius: 20px; border: 1px solid #1a1a1a; }
        .header { text-align: center; margin-bottom: 40px; }
        .logo { font-size: 32px; font-weight: 900; color: #e50914; letter-spacing: -1px; text-transform: uppercase; font-style: italic; }
        .content { line-height: 1.6; font-size: 16px; color: #dddddd; }
        .content p { color: #dddddd; }
        .greeting { font-size: 24px; font-weight: bold; margin-bottom: 20px; color: #ffffff; }
        .notice-card { background-color: #111; padding: 30px; border-radius: 15px; border: 1px solid #222; margin: 30px 0; border-left: 4px solid #e50914; }
        .footer { text-align: center; color: #777777; font-size: 12px; margin-top: 40px; }
        .btn { display: inline-block; background-color: #333; color: #ffffff; font-weight: bold; text-decoration: none; padding: 15px 30px; border-radius: 8px; margin-top: 20px; }
    </style>
</head>
<body>
    <div style="padding: 40px 0;">
        <div class="container">
            <div class="header">
                <div class="logo">CineTube</div>
            </div>
            <div class="content">
                <div class="greeting">Subscription Cancelled</div>
                <p style="color: #dddddd;">Hello <%= userName %>,</p>
                <p style="color: #dddddd;">We're sorry to see you go! This email confirms that your subscription has been cancelled.</p>
                
                <div class="notice-card">
                    <strong style="color: #ffffff;">Access Expiry Date:</strong> <%= expiryDate %><br>
                    <span style="color: #dddddd;">You will continue to have access to all premium features until your current billing period ends on this date.</span>
                </div>

                <p style="color: #dddddd;">Changed your mind? You can reactivate your subscription at any time from your account management page.</p>


                <div style="text-align: center;">
                    <a href="<%= envVars.FRONTEND_URL %>" class="btn">Return to CineTube</a>
                </div>
            </div>
            <div class="footer">
                &copy; <%= new Date().getFullYear() %> CineTube. All rights reserved.<br>
            </div>
        </div>
    </div>
</body>
</html>
